# EvolveX Backend Environment Configuration (Local Development)
APP_ENV=development
APP_NAME=EvolveX
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Local PostgreSQL Connection URL (docker compose service postgres)
DATABASE_URL=postgresql+asyncpg://evolvex_user:evolvex_password@127.0.0.1:5433/evolvex_db

# CORS Allowed Origins (JSON Array)
ALLOWED_ORIGINS=["http://localhost:5173"]
